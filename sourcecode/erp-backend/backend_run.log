      INSERT INTO finance.fiscal_period (fiscal_year, period_no, date_from, date_to, status)
      SELECT 2026, m,
             MAKE_DATE(2026, m, 1),
             (MAKE_DATE(2026, m, 1) + INTERVAL '1 month' - INTERVAL '1 day')::DATE,
             'OPEN'
      FROM generate_series(1, 12) AS m
